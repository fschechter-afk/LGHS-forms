{
  "name": "LJHS Dorm Messenger",
  "short_name": "LJHS Chat",
  "description": "Private, invite-only messaging for LJHS dorm students and faculty.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "background_color": "#0b141a",
  "theme_color": "#128c5e",
  "icons": [
    { "src": "icon.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" },
    { "src": "icon-maskable.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "maskable" }
  ]
}
